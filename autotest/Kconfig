if BUILD_TARGET_AUTOTEST

menu "Autotest configuration"

choice
    bool "Test application implementation"
    default AUTOTEST_C

    config AUTOTEST_C
    bool "C11 test application using the FFI-C UAPI interface"

    config AUTOTEST_RUST
    bool "Rust test application using the native Rust UAPI interface"

endchoice

config TEST_SYSCALL_FUZZ
        bool "Syscall fuzzing campaign (runtime)"
        default n
        help
            Enable a syscall-oriented fuzzing campaign executed from autotest.
            This campaign primarily targets the SVC interface and IPC length
            transitions to surface risky runtime behaviors.

config TEST_SYSCALL_FUZZ_ITERS
        int "Number of syscall fuzzing iterations"
        range 16 4096
        default 512
        depends on TEST_SYSCALL_FUZZ
        help
            Number of iterations for the main syscall fuzzing campaign.

if !TEST_SYSCALL_FUZZ

config AUTOTEST_TIMER_DRIVER
    bool
    default n

config TEST_YIELD
    bool "yield test suite"
    default y

config TEST_HANDLES
    bool "handles access test suite"
    default y

config TEST_SIGNALS
    bool "Signal snd/receive test suite"
    default y

config TEST_IPC
    bool "IPC snd/receive test suite"
    default y

config TEST_RANDOM
    bool "KRNG test suite"
    default y

config TEST_CYCLES
    bool "Cycle measurement test suite"
    default y

config TEST_SLEEP
    bool "Various slepping mode test suite"
    default y

config TEST_GPIO
    bool "GPIO kernel API test suite"
    default n

config TEST_DEVICES
    bool "devices (un)mapping and access API test suite"
    default n

config TEST_SHM
    bool "Shared memory manipulation test suite"
    default y

config TEST_DMA
    bool "Direct Memory Access test suite"
    select TEST_SHM
    default n

config TEST_IRQ
    bool "User interrupts test suite, need timer support at autotest level"
    select AUTOTEST_TIMER_DRIVER
    default n

config TEST_CAPA
    bool "Test that userspace capabilities are properly triggered by the kernel"
    default n

endif

endmenu

endif
